# ============================================================================
#  Ariadne — .gitignore
#  Commits: source code, the configuration baseline, docs, and the folder
#  skeleton. Excludes: the virtual environment, everything generated at
#  runtime (database, indexes, logs), and every private corpus file.
# ============================================================================

# ── Python virtual environment ──────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Python bytecode & build artifacts ───────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
build/
dist/

# ── Test / type / coverage caches ───────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Generated metadata database (SQLite) + its WAL/SHM sidecars ──────────────
storage/metadata.db
storage/metadata.db-*
*.db-wal
*.db-shm
*.db-journal

# ── Generated search indexes (rebuilt by ingest.bat) ────────────────────────
storage/vector/*
!storage/vector/.gitkeep
storage/incremental_work/*
!storage/incremental_work/.gitkeep

# ── Local logs & chat history (runtime, machine-local, may hold query text) ──
storage/logs/*
!storage/logs/.gitkeep

# ── Ingested corpus & processed output (private documents + regenerated) ─────
data/input/*
!data/input/.gitkeep
data/processed/*
!data/processed/.gitkeep

# ── UI-written runtime configuration overrides (machine-specific) ───────────
#   NOTE: this file holds live, machine-local tuning (e.g. the local Tesseract
#   path) written by the settings panel. The committed config/client.yaml is
#   the baseline. See the README/notes before committing this intentionally.
config/ui_overrides.yaml

# ── Evaluation reports (generated by the eval tools) ────────────────────────
reports/*
!reports/.gitkeep

# ── Secrets / environment files ─────────────────────────────────────────────
.env
.env.*

# ── Editor / IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Operating-system cruft ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Evaluation probe output (generated) ──
eval/runs/*
!eval/runs/.gitkeep
